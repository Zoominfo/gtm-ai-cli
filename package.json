{
  "name": "gtm-ai-cli",
  "version": "1.0.0",
  "description": "Command-line interface for the ZoomInfo GTM AI MCP server",
  "type": "module",
  "bin": {
    "gtm": "./dist/js/index.js"
  },
  "files": [
    "dist/index.js",
    "README.md"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "build:ts": "tsc -p tsconfig.build.json && chmod +x dist/js/index.js",
    "build": "bun build ./src/index.ts --compile --minify --outfile dist/gtm",
    "build:all": "bun build ./src/index.ts --compile --minify --target=bun-darwin-arm64 --outfile dist/gtm-macos-arm64 && bun build ./src/index.ts --compile --minify --target=bun-darwin-x64 --outfile dist/gtm-macos-x64 && bun build ./src/index.ts --compile --minify --target=bun-linux-x64 --outfile dist/gtm-linux-x64 && bun build ./src/index.ts --compile --minify --target=bun-windows-x64 --outfile dist/gtm-windows-x64.exe",
    "test": "vitest run -c vitest.config.ts",
    "test:watch": "vitest -c vitest.config.ts",
    "test:live": "vitest run -c vitest.config.live.ts",
    "prepublishOnly": "npm run build:ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@semantic-release/git": "10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.7.0",
    "tsx": "^4.20.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      "@semantic-release/git"
    ]
  }
}
